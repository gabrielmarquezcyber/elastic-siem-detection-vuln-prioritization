{"id":"aad3027e-0913-4594-9e98-1c97b1f440ff","rule_id":"6564c7a2-8379-4e2e-9842-4ce80725a45d","name":"Suspicious PowerShell Flags (EQL) — T1059.001","immutable":false,"rule_source":{"type":"internal"},"version":1,"revision":9,"updated_at":"2025-11-10T22:50:57.157Z","updated_by":"2276008745","created_at":"2025-11-10T00:39:01.546Z","created_by":"2276008745","enabled":true,"interval":"1m","from":"now-3m","to":"now","description":"Detect PowerShell executions with encoded/no-profile/ExecutionPolicy Bypass patterns. Interview/Capstone demo rule.","tags":["T1059.001","PowerShell","Execution","Capstone","Demo"],"author":[],"license":"","threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0002","name":"Execution","reference":"https://attack.mitre.org/tactics/TA0002/"},"technique":[{"id":"T1059","name":"Command and Scripting Interpreter","reference":"https://attack.mitre.org/techniques/T1059/","subtechnique":[{"id":"T1059.001","name":"PowerShell","reference":"https://attack.mitre.org/techniques/T1059/001/"}]}]}],"related_integrations":[],"required_fields":[],"setup":"","false_positives":[],"references":[],"risk_score":75,"risk_score_mapping":[],"severity":"high","severity_mapping":[],"output_index":"","max_signals":100,"exceptions_list":[],"actions":[],"meta":{"kibana_siem_app_url":"https://02cb50714e214eddbdcdee0c84f9d5e1.us-central1.gcp.cloud.es.io/app/security"},"type":"eql","language":"eql","index":["logs-endpoint.events.process-*","logs-*","endpoint.events.*"],"query":"process\n  where event.category == \"process\"\n    and process.name : (\"powershell.exe\", \"pwsh.exe\")\n    and (\n      process.command_line : \"*-enc*\" or\n      process.command_line : \"*-EncodedCommand*\" or\n      process.command_line : \"*-nop*\" or\n      process.command_line : \"*-NoProfile*\"\n    )","filters":[]}
